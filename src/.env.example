# Porta do servidor local (ou do serviço de deploy)
PORT=3000

# Use MySQL localmente se quiser testar no seu computador
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=sua_senha_do_mysql
DB_NAME=portfolio_acessos_luana

# Para deploy com PostgreSQL (Neon, AWS RDS, etc.), descomente e substitua com sua URL.
# O backend ajusta automaticamente sslmode e compatibilidade se precisar.
# DATABASE_URL=postgresql://seu_usuario:sua_senha@host:porta/banco?sslmode=require&uselibpqcompat=true
